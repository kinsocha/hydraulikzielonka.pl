---
import Icon from './Icon.astro';

const steps = [
  { icon: 'phone',            title: 'Zgłoszenie i wycena', description: 'Zadzwoń i krótko opisz problem. Podamy orientacyjny koszt i zaproponujemy szybki termin.' },
  { icon: 'search',           title: 'Diagnostyka na miejscu', description: 'Oglądamy instalację i wybieramy metodę – spirala, ciśnienie albo kamera. Omawiamy zakres prac.' },
  { icon: 'wrench',           title: 'Realizacja', description: 'Usuwamy usterkę i sprawdzamy efekt. Pracujemy bez agresywnej chemii i bez ryzyka dla instalacji.' },
  { icon: 'clipboard-check',  title: 'Odbiór i wskazówki', description: 'Zostawiamy porządek. Tłumaczymy, gdzie był problem, i jak uniknąć go w przyszłości.' },
];
---

<section id="proces" class="py-20 lg:py-28 bg-[#0a0a0f]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Jak <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">działamy</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Cztery kroki – od pierwszego telefonu do zakończenia prac.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, i) => (
        <div class="group bg-white/5 border border-white/10 rounded-2xl p-7 hover:bg-white/10 transition-all flex flex-col">
          <div class="flex items-start justify-between mb-7">
            <div class="p-3.5 bg-violet-500/20 rounded-2xl">
              <Icon name={step.icon} class="w-7 h-7 text-violet-400" />
            </div>
            <span class="text-5xl font-black text-white/[0.06] group-hover:text-white/20 transition-colors leading-none select-none">{i + 1}</span>
          </div>
          <h3 class="text-xl font-semibold mb-3">{step.title}</h3>
          <p class="text-gray-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
