---
import Icon from './Icon.astro';
import { siteConfig, phoneLabel } from '../config/site';
import { locations } from '../data/locations';

const navLinks = [
  { href: '#uslugi', label: 'Usługi' },
  { href: '#dlaczego-my', label: 'Dlaczego my' },
  { href: '#cennik', label: 'Cennik' },
  { href: '#opinie', label: 'Opinie' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-[#0a0a0f]/80 backdrop-blur-xl border-b border-white/10 transition-shadow"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500 to-cyan-500 flex items-center justify-center">
          <Icon name="wrench" class="w-5 h-5 text-white" />
        </div>
        <span class="font-bold text-xl tracking-tight">{siteConfig.name}</span>
      </a>

      <!-- Desktop links -->
      <div class="hidden lg:flex items-center gap-6">
        {navLinks.map(link => (
          <a href={link.href} data-nav-link class="text-gray-400 hover:text-white font-medium transition-colors">
            {link.label}
          </a>
        ))}

        <!-- Okolice dropdown -->
        <div class="relative" id="areas-wrap">
          <button id="areas-btn" class="flex items-center gap-1 text-gray-400 hover:text-white font-medium transition-colors">
            Okolice
            <Icon name="chevron-down" class="w-4 h-4" />
          </button>
          <div id="areas-menu" class="absolute top-full right-0 pt-2 w-56 hidden">
            <div class="bg-[#13131f] rounded-xl shadow-xl border border-white/10 py-2">
              {locations.map(l => (
                <a href={`/${l.slug}`} class="block px-4 py-2 text-gray-300 hover:bg-white/5 hover:text-cyan-300 transition-colors">
                  Hydraulik {l.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={`tel:${siteConfig.phoneTel}`}
          class="flex items-center gap-2 bg-gradient-to-r from-violet-600 to-cyan-600 text-white px-5 py-2.5 rounded-xl font-medium hover:opacity-90 transition-opacity"
        >
          <Icon name="phone" class="w-4 h-4" />
          <span>{phoneLabel}</span>
        </a>
      </div>

      <!-- Mobile button -->
      <button id="mobile-btn" class="lg:hidden p-2 rounded-lg text-white hover:bg-white/10 transition-colors" aria-label="Menu">
        <Icon name="menu" id="icon-menu" class="w-6 h-6" />
        <Icon name="x" id="icon-close" class="w-6 h-6 hidden" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden absolute top-full left-0 right-0 bg-[#0a0a0f] border-t border-white/10 shadow-xl">
    <div class="px-4 py-6 space-y-1 max-h-[80vh] overflow-y-auto">
      {navLinks.map(link => (
        <a href={link.href} data-nav-link class="block py-2 text-gray-300 font-medium hover:text-white transition-colors">
          {link.label}
        </a>
      ))}
      <div class="border-t border-white/10 pt-4 mt-4">
        <p class="text-sm font-semibold text-gray-500 mb-2">Okolice:</p>
        {locations.map(l => (
          <a href={`/${l.slug}`} class="block py-2 text-gray-300 hover:text-cyan-300 transition-colors">
            Hydraulik {l.name}
          </a>
        ))}
      </div>
      <a
        href={`tel:${siteConfig.phoneTel}`}
        class="flex items-center justify-center gap-2 w-full bg-gradient-to-r from-violet-600 to-cyan-600 text-white px-5 py-3 rounded-xl font-medium mt-4"
      >
        <Icon name="phone" class="w-4 h-4" />
        <span>{phoneLabel}</span>
      </a>
    </div>
  </div>
</nav>

<script>
  // Cień przy przewijaniu
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) navbar?.classList.add('shadow-lg', 'shadow-black/30');
    else navbar?.classList.remove('shadow-lg', 'shadow-black/30');
  }, { passive: true });

  // Menu mobilne
  const mobileBtn  = document.getElementById('mobile-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu   = document.getElementById('icon-menu');
  const iconClose  = document.getElementById('icon-close');

  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // Rozwijane "Okolice" (hover)
  const wrap = document.getElementById('areas-wrap');
  const menu = document.getElementById('areas-menu');
  wrap?.addEventListener('mouseenter', () => menu?.classList.remove('hidden'));
  wrap?.addEventListener('mouseleave', () => menu?.classList.add('hidden'));

  // Płynne przewijanie / przekierowanie dla linków kotwicowych
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const href = a.getAttribute('href');
      if (!href) return;
      if (window.location.pathname === '/') {
        e.preventDefault();
        document.querySelector(href)?.scrollIntoView({ behavior: 'smooth' });
      } else {
        e.preventDefault();
        window.location.href = '/' + href;
      }
      mobileMenu?.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
