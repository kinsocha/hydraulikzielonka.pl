---
import Default from '../layouts/Default.astro';
import LocationContent from '../components/LocationContent.astro';
import { locations } from '../data/locations';

const location = locations.find(l => l.slug === 'hydraulik-kobylka')!;
---
<Default title={location.metaTitle} description={location.metaDescription}>
  <LocationContent location={location} />
</Default>
