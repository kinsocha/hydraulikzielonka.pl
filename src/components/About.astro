---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';

const miniStats = [
  { value: `${siteConfig.experienceYears}+`, label: 'lat doświadczenia', color: 'text-violet-400' },
  { value: `${siteConfig.clients}+`,         label: 'zrealizowanych zleceń', color: 'text-cyan-400' },
  { value: `${siteConfig.successRate}%`,      label: 'skuteczność', color: 'text-violet-400' },
  { value: '24/7',                            label: 'awaryjny dyżur', color: 'text-cyan-400' },
];

const tags = ['Udrażnianie kanalizacji', 'Naprawy hydrauliczne', 'Montaż armatury', 'Inspekcja kamerą', 'Przeglądy instalacji'];
---

<section id="o-nas" class="py-20 lg:py-28 bg-gradient-to-b from-transparent via-cyan-950/10 to-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <div class="bg-gradient-to-br from-violet-500/10 to-cyan-500/10 rounded-3xl p-1">
          <div class="bg-[#1a1a2e] rounded-2xl p-8">
            <div class="grid grid-cols-2 gap-6">
              {miniStats.map(s => (
                <div class="bg-white/5 rounded-xl p-6 text-center">
                  <div class:list={['text-3xl font-bold mb-1', s.color]}>{s.value}</div>
                  <div class="text-sm text-gray-400">{s.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <div class="inline-flex items-center gap-2 bg-cyan-500/10 border border-cyan-500/20 rounded-full px-4 py-2 mb-6">
          <Icon name="star" class="w-4 h-4 text-cyan-400" />
          <span class="text-base text-cyan-300">O firmie</span>
        </div>

        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Profesjonalne usługi <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">hydrauliczne</span>
        </h2>

        <p class="text-gray-400 text-lg mb-6 leading-relaxed">
          Hydraulik Zielonka to lokalna firma z wieloletnim doświadczeniem w branży hydraulicznej.
          Specjalizujemy się w udrażnianiu kanalizacji i naprawach instalacji sanitarnych.
        </p>

        <p class="text-gray-400 text-lg mb-8 leading-relaxed">
          Stale inwestujemy w sprzęt i szkolenia. Działamy w Zielonce i okolicach, oferując
          konkurencyjne ceny oraz elastyczne terminy. Bez ściemy, z wyceną przed pracą.
        </p>

        <div class="flex flex-wrap gap-3">
          {tags.map(tag => (
            <span class="bg-white/5 border border-white/10 rounded-full px-4 py-2 text-base text-gray-300">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
