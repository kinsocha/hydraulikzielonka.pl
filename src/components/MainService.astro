---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';

const benefits = [
  'Usuwanie zatorów tłuszczowych',
  'Czyszczenie rur z osadów',
  'Udrażnianie odpływów łazienkowych',
  'Czyszczenie pionów kanalizacyjnych',
  'Inspekcja kamerą przed i po czyszczeniu',
  'Profilaktyczne płukanie instalacji',
];

const priceList = [
  { name: 'Udrażnianie zlewu',     price: 'od 350 zł' },
  { name: 'Udrażnianie WC',        price: 'od 350 zł' },
  { name: 'Czyszczenie pionu',     price: 'od 650 zł' },
  { name: 'Inspekcja kamerą',      price: 'od 350 zł' },
  { name: 'Płukanie ciśnieniowe',  price: 'od 650 zł' },
  { name: 'Montaż baterii',        price: 'od 350 zł' },
  { name: 'Naprawa spłuczki',      price: 'od 350 zł' },
  { name: 'Montaż wodomierzy',     price: 'od 350 zł' },
  { name: 'Usługi hydrauliczne',   price: 'od 350 zł' },
];
---

<section id="cennik" class="py-20 lg:py-28 bg-gradient-to-b from-transparent via-violet-950/20 to-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="inline-flex items-center gap-2 bg-violet-500/10 border border-violet-500/20 rounded-full px-4 py-2 mb-6">
          <Icon name="droplets" class="w-4 h-4 text-violet-400" />
          <span class="text-base text-violet-300">Główna usługa</span>
        </div>

        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Udrażnianie <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">kanalizacji</span>
        </h2>

        <p class="text-gray-400 text-lg mb-8 leading-relaxed">
          Zatory to najczęstszy problem w domach i mieszkaniach. Doświadczenie i profesjonalny
          sprzęt pozwalają usunąć każdy z nich szybko i skutecznie. Stosujemy metody mechaniczne
          (spirale) oraz ciśnieniowe (WUKO), dobierając technikę do rodzaju zatoru.
        </p>

        <div class="space-y-4 mb-8">
          {benefits.map(item => (
            <div class="flex items-center gap-3">
              <Icon name="check-circle" class="w-5 h-5 text-cyan-400 flex-shrink-0" />
              <span class="text-gray-300">{item}</span>
            </div>
          ))}
        </div>

        <a
          href={`tel:${siteConfig.phoneTel}`}
          class="inline-flex items-center gap-2 bg-gradient-to-r from-violet-600 to-cyan-600 px-8 py-4 rounded-2xl font-semibold text-lg hover:opacity-90 transition-opacity"
        >
          <Icon name="phone" class="w-5 h-5" />
          <span>Zamów udrażnianie</span>
        </a>
      </div>

      <div class="relative">
        <div class="bg-gradient-to-br from-violet-500/10 to-cyan-500/10 rounded-3xl p-8 border border-white/10">
          <div class="bg-[#1a1a2e] rounded-2xl p-8">
            <div class="text-center mb-8">
              <div class="text-5xl lg:text-6xl font-bold bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent mb-2">
                od 350 zł
              </div>
              <p class="text-gray-400">Cena za standardowe udrażnianie</p>
            </div>

            <div class="space-y-1">
              {priceList.map((row, i) => (
                <div class:list={['flex justify-between items-center py-3', i < priceList.length - 1 && 'border-b border-white/10']}>
                  <span class="text-gray-300">{row.name}</span>
                  <span class="text-white font-medium">{row.price}</span>
                </div>
              ))}
            </div>

            <p class="text-gray-500 text-sm text-center mt-6">
              Ceny orientacyjne. Dokładną wycenę podajemy przed przyjazdem.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
