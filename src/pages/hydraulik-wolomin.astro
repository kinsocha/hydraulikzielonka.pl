---
import '../styles/sections.css';

const phone = '';                 // <- WPISZ numer, np. '500 600 700'
const phoneLabel = phone || 'Zadzwoń teraz';
const phoneHref = phone ? `tel:+48${phone.replace(/\s/g, '')}` : '#';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  <title>Hydraulik Wołomin - usługi hydrauliczne i udrażnianie | Hydraulik Zielonka</title>
  <meta name="description" content="Hydraulik Wołomin - udrażnianie kanalizacji, naprawa instalacji, montaż armatury, pogotowie. Szybki dojazd, wycena przed pracą." />

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Hydraulik Zielonka - Wołomin",
  "url": "https://hydraulik-zielonka.pl/hydraulik-wolomin",
  "telephone": "",
  "areaServed": {
    "@type": "City",
    "name": "Wołomin"
  },
  "priceRange": "$$"
}
  </script>

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Jakie usługi hydrauliczne wykonujecie w Wołominie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pełen zakres: udrażnianie kanalizacji, naprawę i wymianę instalacji, montaż armatury, podłączenia AGD, inspekcję kamerą oraz pogotowie przy awariach."
      }
    },
    {
      "@type": "Question",
      "name": "Jak szybko przyjedziecie do Wołomina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wołomin jest nieco dalej niż Ząbki czy Marki, ale nadal w naszym standardowym obszarze. Zwykle dojeżdżamy tego samego dnia."
      }
    },
    {
      "@type": "Question",
      "name": "Udrażniacie piony w blokach z wielkiej płyty?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. To częste zlecenie. Łączymy sprężynę elektryczną z płukaniem ciśnieniowym, żeby usunąć korek i wypłukać osady z całego odcinka."
      }
    },
    {
      "@type": "Question",
      "name": "Naprawiacie awarie po godzinach pracy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. Przy pilnych awariach, takich jak pęknięta rura czy zalanie, jesteśmy dostępni również wieczorami i w weekendy."
      }
    },
    {
      "@type": "Question",
      "name": "Czy podajecie cenę przed przyjazdem?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. Po krótkim opisie problemu podajemy orientacyjny koszt jeszcze przez telefon. Bez ukrytych opłat, możliwa faktura VAT."
      }
    }
  ]
}
  </script>
</head>

<body data-bg="premium">
  <div class="page-shell">

    <header class="topbar">
      <div class="container nav">
        <a href="/" class="logo" aria-label="Hydraulik Zielonka strona główna">
          <span class="logo__mark">🔧</span>
          <span class="logo__name">Hydraulik Zielonka</span>
        </a>
        <nav class="nav__links" aria-label="Główna nawigacja">
          <a href="/#uslugi">Usługi</a>
          <a href="/#proces">Jak działamy</a>
          <a href="/#cennik">Cennik</a>
          <a href="/#faq">FAQ</a>
          <a href="/#kontakt">Kontakt</a>
        </nav>
        <div class="nav__actions">
          <a class="phone-link" href={phoneHref}><span>☎</span> {phoneLabel}</a>
          <a class="btn-new btn-new--primary" href={phoneHref}>Zadzwoń teraz</a>
        </div>
      </div>
    </header>

    <main>
      <!-- INTRO -->
      <section class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker"><a href="/" style="color:inherit">Strona główna</a> / Hydraulik Wołomin</p>
              <h2 class="section-title">Hydraulik Wołomin - udrażnianie i naprawy</h2>
            </div>
            <p class="section-desc">Dojeżdżamy do Wołomin przy awariach, zatkanych odpływach i pracach instalacyjnych. Wycena przed przyjazdem, faktura VAT.</p>
          </div>
          <div class="hero-buttons" style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px">
            <a class="btn-new btn-new--primary" href={phoneHref}>📞 {phoneLabel}</a>
            <a class="btn-new btn-new--ghost" href="#zakres">Zobacz zakres usług</a>
          </div>
        </div>
      </section>

      <!-- ZAKRES -->
      <section id="zakres" class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker">Co robimy w Wołomin</p>
              <h2 class="section-title">Zakres usług</h2>
            </div>
            <p class="section-desc">Dobieramy metodę do problemu i instalacji. Mieszkania, domy jednorodzinne, bloki i lokale usługowe.</p>
          </div>
          <div class="service-grid">
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">💧</div>
              <h3>Udrażnianie kanalizacji</h3>
              <p>Mechaniczne i ciśnieniowe usuwanie zatorów w zlewach, toaletach, pionach i odpływach.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">🔧</div>
              <h3>Naprawa instalacji</h3>
              <p>Wymiana zaworów, naprawa przecieków, regeneracja uszczelek, podłączenia AGD.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">📹</div>
              <h3>Inspekcja kamerą</h3>
              <p>Diagnostyka wnętrza rur kamerą. Lokalizacja uszkodzeń, załamań i wrastających korzeni.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
          </div>
        </div>
      </section>

      <!-- OBSZAR -->
      <section class="new-section">
        <div class="container bento">
          <article class="panel diagnostic reveal">
            <p class="section-kicker">Opis</p>
            <h2>Hydraulik i udrażnianie w Wołomin</h2>
            <p>Wołomin to największa miejscowość w okolicy i bardzo zróżnicowana zabudowa. Bloki z wielkiej płyty, kamienice w centrum, osiedla domów na obrzeżach. W blokach najczęściej udrażniamy piony i podejścia kuchenne, w domach przyłącza i rury zewnętrzne. Robimy też pełen zakres prac hydraulicznych: naprawę i wymianę zaworów, montaż umywalek, toalet i baterii, podłączenia pralek i zmywarek.</p>
          </article>
          <aside class="panel process-panel reveal">
            <h2>Obszar działania</h2>
            <p style="color:var(--muted);margin:0 0 6px">Osiedla i części miejscowości:</p>
            <ul class="check-list">
              <li>Centrum</li>
              <li>Sławek</li>
              <li>Lipinki</li>
              <li>okolice Alei Niepodległości</li>
            </ul>
            <p style="color:var(--muted);margin:14px 0 0;line-height:1.6"><strong style="color:var(--ink)">Dojeżdżamy m.in. na ulice:</strong> Legionów • 1 Maja • Kościelna • Wileńska • Lipińska • Sasina • Geodetów • Armii Krajowej • Aleja Niepodległości • Sikorskiego • Warszawska • Ogrodowa • Moniuszki • Duczkowska i pozostałe ulice miejscowości Wołomin.</p>
          </aside>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" class="faq-section">
        <div class="container faq-grid">
          <div class="reveal">
            <p class="section-kicker">Pytania klientów</p>
            <h2 class="section-title">FAQ - Hydraulik Wołomin</h2>
            <p class="section-desc">Najczęstsze pytania przed telefonem.</p>
          </div>
          <div class="faq-list reveal">
            <article class="faq-item is-open">
              <button class="faq-question" type="button"><span>Jakie usługi hydrauliczne wykonujecie w Wołominie?</span><span>+</span></button>
              <div class="faq-answer"><p>Pełen zakres: udrażnianie kanalizacji, naprawę i wymianę instalacji, montaż armatury, podłączenia AGD, inspekcję kamerą oraz pogotowie przy awariach.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Jak szybko przyjedziecie do Wołomina?</span><span>+</span></button>
              <div class="faq-answer"><p>Wołomin jest nieco dalej niż Ząbki czy Marki, ale nadal w naszym standardowym obszarze. Zwykle dojeżdżamy tego samego dnia.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Udrażniacie piony w blokach z wielkiej płyty?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak. To częste zlecenie. Łączymy sprężynę elektryczną z płukaniem ciśnieniowym, żeby usunąć korek i wypłukać osady z całego odcinka.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Naprawiacie awarie po godzinach pracy?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak. Przy pilnych awariach, takich jak pęknięta rura czy zalanie, jesteśmy dostępni również wieczorami i w weekendy.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Czy podajecie cenę przed przyjazdem?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak. Po krótkim opisie problemu podajemy orientacyjny koszt jeszcze przez telefon. Bez ukrytych opłat, możliwa faktura VAT.</p></div>
            </article>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section id="kontakt" class="cta-section">
        <div class="container">
          <div class="final-cta reveal">
            <div class="final-cta__content">
              <div>
                <h2>Potrzebujesz hydraulika w Wołomin?</h2>
                <p>Opisz krótko problem przez telefon - łatwiej dobrać metodę i podać orientacyjny koszt. Działamy w Wołomin i okolicach.</p>
              </div>
              <div class="final-cta__box">
                <strong>{phoneLabel}</strong>
                <span>Hydraulik Zielonka - Wołomin i okolice</span>
                <div style="height: 18px"></div>
                <a class="btn-new btn-new--primary" href={phoneHref}>📞 Zadzwoń teraz</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- INNE MIEJSCOWOŚCI -->
      <section class="new-section">
        <div class="container">
          <h2 class="section-title" style="margin-bottom:18px">Działamy też w okolicy</h2>
          <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-start">
            <a class="btn-new btn-new--ghost" href="/hydraulik-zabki">Hydraulik Ząbki</a>
            <a class="btn-new btn-new--ghost" href="/hydraulik-marki">Hydraulik Marki</a>
            <a class="btn-new btn-new--ghost" href="/hydraulik-kobylka">Hydraulik Kobyłka</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="new-footer">
      <div class="container footer-grid">
        <div>© 2026 Hydraulik Zielonka</div>
        <div>Udrażnianie • Naprawy • Montaż armatury • Inspekcja kamerą</div>
      </div>
    </footer>

    <a class="mobile-cta" href={phoneHref}>📞 Zadzwoń: {phoneLabel}</a>
  </div>

  <script>
    // reveal
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
    // FAQ
    document.querySelectorAll('.faq-item').forEach(item => {
      item.querySelector('.faq-question').addEventListener('click', () => {
        document.querySelectorAll('.faq-item').forEach(o => { if (o !== item) o.classList.remove('is-open'); });
        item.classList.toggle('is-open');
      });
    });
  </script>
</body>
</html>
