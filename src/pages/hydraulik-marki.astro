---
import '../styles/sections.css';

const phone = '';                 // <- WPISZ numer, np. '500 600 700'
const phoneLabel = phone || 'Zadzwoń teraz';
const phoneHref = phone ? `tel:+48${phone.replace(/\s/g, '')}` : '#';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  <title>Hydraulik Marki - usługi hydrauliczne i udrażnianie | Hydraulik Zielonka</title>
  <meta name="description" content="Hydraulik Marki - udrażnianie kanalizacji, naprawa instalacji, montaż armatury, pogotowie. Szybki dojazd, wycena przed pracą." />

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Hydraulik Zielonka - Marki",
  "url": "https://hydraulik-zielonka.pl/hydraulik-marki",
  "telephone": "",
  "areaServed": {
    "@type": "City",
    "name": "Marki"
  },
  "priceRange": "$$"
}
  </script>

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Czyścicie przyłącza i rury zewnętrzne w domach w Markach?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. Przy zabudowie jednorodzinnej to częste zlecenie. Czyścimy przyłącza do kanalizacji miejskiej i do szamba, studzienki oraz rury deszczowe metodą ciśnieniową."
      }
    },
    {
      "@type": "Question",
      "name": "Sprężyna nie dała rady. Co dalej?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Na długich odcinkach rur zewnętrznych sprężyna bywa za krótka. Wtedy używamy płukania hydrodynamicznego, które rozbija i wypłukuje osady na całej długości przewodu."
      }
    },
    {
      "@type": "Question",
      "name": "Jak szybko przyjedziecie do Marek?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Marki leżą blisko Zielonki, więc dojeżdżamy sprawnie, zwykle tego samego dnia. W pilnych awariach reagujemy priorytetowo."
      }
    },
    {
      "@type": "Question",
      "name": "Wystawiacie fakturę VAT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak, dla klientów indywidualnych i firm. Możliwe są też cykliczne przeglądy instalacji, na przykład w wynajmowanych domach."
      }
    },
    {
      "@type": "Question",
      "name": "Robicie drobne naprawy, czy tylko duże zlecenia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Robimy jedno i drugie. Cieknący kran, wymiana syfonu, podłączenie zmywarki. Takie prace również wykonujemy podczas jednej wizyty."
      }
    }
  ]
}
  </script>
</head>

<body data-bg="premium">
  <div class="page-shell">

    <header class="topbar">
      <div class="container nav">
        <a href="/" class="logo" aria-label="Hydraulik Zielonka strona główna">
          <span class="logo__mark">🔧</span>
          <span class="logo__name">Hydraulik Zielonka</span>
        </a>
        <nav class="nav__links" aria-label="Główna nawigacja">
          <a href="/#uslugi">Usługi</a>
          <a href="/#proces">Jak działamy</a>
          <a href="/#cennik">Cennik</a>
          <a href="/#faq">FAQ</a>
          <a href="/#kontakt">Kontakt</a>
        </nav>
        <div class="nav__actions">
          <a class="phone-link" href={phoneHref}><span>☎</span> {phoneLabel}</a>
          <a class="btn-new btn-new--primary" href={phoneHref}>Zadzwoń teraz</a>
        </div>
      </div>
    </header>

    <main>
      <!-- INTRO -->
      <section class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker"><a href="/" style="color:inherit">Strona główna</a> / Hydraulik Marki</p>
              <h2 class="section-title">Hydraulik Marki - udrażnianie i naprawy</h2>
            </div>
            <p class="section-desc">Dojeżdżamy do Marki przy awariach, zatkanych odpływach i pracach instalacyjnych. Wycena przed przyjazdem, faktura VAT.</p>
          </div>
          <div class="hero-buttons" style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px">
            <a class="btn-new btn-new--primary" href={phoneHref}>📞 {phoneLabel}</a>
            <a class="btn-new btn-new--ghost" href="#zakres">Zobacz zakres usług</a>
          </div>
        </div>
      </section>

      <!-- ZAKRES -->
      <section id="zakres" class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker">Co robimy w Marki</p>
              <h2 class="section-title">Zakres usług</h2>
            </div>
            <p class="section-desc">Dobieramy metodę do problemu i instalacji. Mieszkania, domy jednorodzinne, bloki i lokale usługowe.</p>
          </div>
          <div class="service-grid">
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">💧</div>
              <h3>Udrażnianie kanalizacji</h3>
              <p>Mechaniczne i ciśnieniowe usuwanie zatorów w zlewach, toaletach, pionach i odpływach.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">🔧</div>
              <h3>Naprawa instalacji</h3>
              <p>Wymiana zaworów, naprawa przecieków, regeneracja uszczelek, podłączenia AGD.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">📹</div>
              <h3>Inspekcja kamerą</h3>
              <p>Diagnostyka wnętrza rur kamerą. Lokalizacja uszkodzeń, załamań i wrastających korzeni.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
          </div>
        </div>
      </section>

      <!-- OBSZAR -->
      <section class="new-section">
        <div class="container bento">
          <article class="panel diagnostic reveal">
            <p class="section-kicker">Opis</p>
            <h2>Hydraulik i udrażnianie w Marki</h2>
            <p>W Markach przeważa zabudowa jednorodzinna. Częściej niż w bloku spotykamy tu zatory na przyłączach, problemy ze studzienkami i rurami zewnętrznymi. Na długich odcinkach sprężyna bywa za krótka. Wtedy sprawdza się płukanie ciśnieniowe, które wypłukuje osady i piasek po opadach. Robimy też klasyczną robotę hydrauliczną: wymianę zaworów, naprawę przecieków, montaż armatury i podejść pod sprzęty AGD.</p>
          </article>
          <aside class="panel process-panel reveal">
            <h2>Obszar działania</h2>
            <p style="color:var(--muted);margin:0 0 6px">Osiedla i części miejscowości:</p>
            <ul class="check-list">
              <li>Centrum</li>
              <li>Pustelnik</li>
              <li>Struga</li>
              <li>okolice Alei Piłsudskiego</li>
            </ul>
            <p style="color:var(--muted);margin:14px 0 0;line-height:1.6"><strong style="color:var(--ink)">Dojeżdżamy m.in. na ulice:</strong> Al. Marszałka Piłsudskiego • Fabryczna • Okólna • Lisa Kuli • Sosnowa • Legionowa • Słoneczna • Bandurskiego • Pomnikowa • Spacerowa • Kościuszki • Zygmuntowska • Duża • Wczasowa i pozostałe ulice miejscowości Marki.</p>
          </aside>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" class="faq-section">
        <div class="container faq-grid">
          <div class="reveal">
            <p class="section-kicker">Pytania klientów</p>
            <h2 class="section-title">FAQ - Hydraulik Marki</h2>
            <p class="section-desc">Najczęstsze pytania przed telefonem.</p>
          </div>
          <div class="faq-list reveal">
            <article class="faq-item is-open">
              <button class="faq-question" type="button"><span>Czyścicie przyłącza i rury zewnętrzne w domach w Markach?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak. Przy zabudowie jednorodzinnej to częste zlecenie. Czyścimy przyłącza do kanalizacji miejskiej i do szamba, studzienki oraz rury deszczowe metodą ciśnieniową.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Sprężyna nie dała rady. Co dalej?</span><span>+</span></button>
              <div class="faq-answer"><p>Na długich odcinkach rur zewnętrznych sprężyna bywa za krótka. Wtedy używamy płukania hydrodynamicznego, które rozbija i wypłukuje osady na całej długości przewodu.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Jak szybko przyjedziecie do Marek?</span><span>+</span></button>
              <div class="faq-answer"><p>Marki leżą blisko Zielonki, więc dojeżdżamy sprawnie, zwykle tego samego dnia. W pilnych awariach reagujemy priorytetowo.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Wystawiacie fakturę VAT?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak, dla klientów indywidualnych i firm. Możliwe są też cykliczne przeglądy instalacji, na przykład w wynajmowanych domach.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Robicie drobne naprawy, czy tylko duże zlecenia?</span><span>+</span></button>
              <div class="faq-answer"><p>Robimy jedno i drugie. Cieknący kran, wymiana syfonu, podłączenie zmywarki. Takie prace również wykonujemy podczas jednej wizyty.</p></div>
            </article>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section id="kontakt" class="cta-section">
        <div class="container">
          <div class="final-cta reveal">
            <div class="final-cta__content">
              <div>
                <h2>Potrzebujesz hydraulika w Marki?</h2>
                <p>Opisz krótko problem przez telefon - łatwiej dobrać metodę i podać orientacyjny koszt. Działamy w Marki i okolicach.</p>
              </div>
              <div class="final-cta__box">
                <strong>{phoneLabel}</strong>
                <span>Hydraulik Zielonka - Marki i okolice</span>
                <div style="height: 18px"></div>
                <a class="btn-new btn-new--primary" href={phoneHref}>📞 Zadzwoń teraz</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- INNE MIEJSCOWOŚCI -->
      <section class="new-section">
        <div class="container">
          <h2 class="section-title" style="margin-bottom:18px">Działamy też w okolicy</h2>
          <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-start">
            <a class="btn-new btn-new--ghost" href="/hydraulik-zabki">Hydraulik Ząbki</a>
            <a class="btn-new btn-new--ghost" href="/hydraulik-kobylka">Hydraulik Kobyłka</a>
            <a class="btn-new btn-new--ghost" href="/hydraulik-wolomin">Hydraulik Wołomin</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="new-footer">
      <div class="container footer-grid">
        <div>© 2026 Hydraulik Zielonka</div>
        <div>Udrażnianie • Naprawy • Montaż armatury • Inspekcja kamerą</div>
      </div>
    </footer>

    <a class="mobile-cta" href={phoneHref}>📞 Zadzwoń: {phoneLabel}</a>
  </div>

  <script>
    // reveal
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
    // FAQ
    document.querySelectorAll('.faq-item').forEach(item => {
      item.querySelector('.faq-question').addEventListener('click', () => {
        document.querySelectorAll('.faq-item').forEach(o => { if (o !== item) o.classList.remove('is-open'); });
        item.classList.toggle('is-open');
      });
    });
  </script>
</body>
</html>
