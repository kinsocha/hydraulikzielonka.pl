---
import '../styles/sections.css';
import '../styles/index-style.css';

const phone = '';                 // <- WPISZ numer, np. '500 600 700'
const phoneLabel = phone || 'Zadzwoń teraz';
const phoneHref = phone ? `tel:+48${phone.replace(/\s/g, '')}` : '#';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,300;1,400&display=swap" rel="stylesheet" />
  <title>Hydraulik Zielonka - udrażnianie kanalizacji i usługi hydrauliczne</title>
  <meta name="description" content="Hydraulik Zielonka - udrażnianie kanalizacji, naprawa instalacji, montaż armatury i pogotowie 24/7. Zielonka i okolice. Wycena przed pracą." />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Hydraulik Zielonka",
    "image": "https://hydraulik-zielonka.pl/logo.png",
    "@id": "",
    "url": "https://hydraulik-zielonka.pl",
    "telephone": "",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "558"
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Zielonka i okolice",
      "addressLocality": "Zielonka",
      "postalCode": "00-001",
      "addressCountry": "PL"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 52.3036,
      "longitude": 21.1556
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    }
  }
  </script>

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Dlaczego rura zatyka się ponownie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Najczęściej przez tłuszcz, osad, zbyt mały spadek, źle wykonane podejście albo zator znajdujący się głębiej niż sam syfon."
      }
    },
    {
      "@type": "Question",
      "name": "Czy chemia do rur wystarczy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Przy lekkim osadzie czasem pomaga, ale przy twardym zatorze może pogorszyć sytuację i utrudnić późniejszą pracę mechaniczną."
      }
    },
    {
      "@type": "Question",
      "name": "Kiedy potrzebna jest kamera?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gdy problem wraca, woda cofa się mimo udrażniania albo podejrzewamy uszkodzenie, przeciwspadek lub zalegający osad w rurze."
      }
    },
    {
      "@type": "Question",
      "name": "Czy da się podać cenę przez telefon?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Da się podać widełki, ale dokładna cena zależy od rodzaju awarii, dostępu do instalacji i metody potrzebnej do usunięcia zatoru."
      }
    }
  ]
}
  </script>


  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

  

  <!-- Hero / phone mockup styles -->
</head>

<body data-bg="premium">
  <div class="page-shell">


    <header class="topbar">
      <div class="container nav">
        <a href="#" class="logo" aria-label="Hydraulik Zielonka strona główna">
          <span class="logo__mark">🔧</span>
          <span class="logo__name">Hydraulik Zielonka</span>
        </a>
        <nav class="nav__links" aria-label="Główna nawigacja">
          <a href="#uslugi">Usługi</a>
          <a href="#proces">Jak działamy</a>
          <a href="#cennik">Cennik</a>
          <a href="#faq">FAQ</a>
          <a href="#kontakt">Kontakt</a>
        </nav>
        <div class="nav__actions">
          <a class="phone-link" href={phoneHref}><span>☎</span> {phoneLabel}</a>
          <a class="btn-new btn-new--primary" href={phoneHref}>Zadzwoń teraz</a>
        </div>
      </div>
    </header>

    <main>

      <!-- ═══════════════════════════════════════════════════
           HERO - aktualny, bez zmian
      ════════════════════════════════════════════════════ -->
      <section class="hero">
        <div class="hero-content">
          <h1>
            <span class="h1-label">Hydraulik <span class="h1-accent">Zielonka</span></span>
            <span class="h1-main"><span class="h1-dark">Pogotowie hydrauliczne</span> 24/7</span>
            <span class="h1-sub">Udrażnianie rur, zlewów i kanalizacji</span>
          </h1>
          <p class="hero-subtitle">Lokalny hydraulik z Zielonki. Pomagam rzetelnie: udrażnianie kanalizacji, naprawy instalacji, montaż armatury.</p>
          <div class="hero-buttons">
            <a href={phoneHref} class="btn-primary">
              <span class="btn-label">📞 Zadzwoń teraz</span>
            </a>
            <a href="#uslugi" class="btn-secondary btn-nebula">
              <div class="btn-glass-outer"></div>
              <div class="btn-glass-inner">
                <div class="btn-smoke" id="smoke-2"></div>
                <canvas class="btn-canvas" id="canvas-2"></canvas>
              </div>
              <span class="btn-label">Zobacz usługi →</span>
            </a>
          </div>
          <div class="hero-stats">
            <div class="stat"><div class="stat-number">15+</div><div class="stat-label">lat doświadczenia</div></div>
            <div class="stat"><div class="stat-number">500+</div><div class="stat-label">zadowolonych klientów</div></div>
            <div class="stat"><div class="stat-number">24/7</div><div class="stat-label">dostępność</div></div>
          </div>
        </div>

        <div class="hero-visual">
          <div class="floating-photos">
            <div class="worker-photo">
              <svg viewBox="0 0 100 100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"><circle cx="50" cy="35" r="20" fill="#f5d0c5"/><ellipse cx="50" cy="85" rx="30" ry="25" fill="#1565C0"/></svg>
            </div>
            <div class="worker-photo">
              <svg viewBox="0 0 100 100" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);"><circle cx="50" cy="35" r="20" fill="#d4a574"/><ellipse cx="50" cy="85" rx="30" ry="25" fill="#FF6F00"/></svg>
            </div>
            <div class="worker-photo">
              <svg viewBox="0 0 100 100" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);"><circle cx="50" cy="35" r="20" fill="#f5d0c5"/><ellipse cx="50" cy="85" rx="30" ry="25" fill="#0D47A1"/></svg>
            </div>
            <div class="worker-photo">
              <svg viewBox="0 0 100 100" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);"><circle cx="50" cy="35" r="20" fill="#8d6e63"/><ellipse cx="50" cy="85" rx="30" ry="25" fill="#1976D2"/></svg>
            </div>
          </div>
          <svg class="deco-line deco-line-1" viewBox="0 0 100 50"><path d="M0 25 Q50 0 100 25 T200 25" stroke-dasharray="5,5"/></svg>
          <svg class="deco-line deco-line-2" viewBox="0 0 80 40"><path d="M0 20 Q40 0 80 20" stroke-dasharray="5,5"/></svg>

          <div class="phone-mockup" aria-label="Wizualizacja zgłoszenia hydraulicznego">
            <div class="phone-mockup__notch"></div>
            <div class="phone-mockup__screen">
              <div class="app-top">
                <div>
                  <strong>Hydraulik na telefon</strong>
                </div>
                <div class="avatar">HF</div>
              </div>

              <div class="trust-badge" style="margin-top: 8px;">
                <div class="trust-badge-top">
                  <svg viewBox="0 0 24 24" width="18" height="18" style="flex-shrink:0">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                  </svg>
                  <span class="trust-badge-google-label">Google Moja Firma</span>
                </div>
                <div class="trust-badge-middle">
                  <span class="trust-badge-count">558 Opinii</span>
                </div>
                <div class="trust-badge-bottom">
                  <span class="trust-badge-score">5,0</span>
                  <span class="trust-badge-stars">★★★★★</span>
                </div>
              </div>

              <div class="availability-bar">
                <span class="availability-dot"></span>
                <span class="availability-text">Technik dostępny teraz</span>
              </div>

              <div class="app-alert">
                <small>#PilnaAwaria</small>
                <h3>Fachowiec dobiera metodę udrażniania</h3>
                <span>sprawdź zakres</span>
              </div>

              <div style="height: 8px"></div>

              <div class="step">
                <span class="step__num">1</span>
                <strong>Objaw</strong>
                <span>Woda stoi, cofa się albo słychać bulgotanie.</span>
              </div>

              <a href={phoneHref} class="phone-call-cta">
                📞 {phoneLabel}
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           USŁUGI
      ════════════════════════════════════════════════════ -->
      <section id="uslugi" class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker">Zakres usług</p>
              <h2 class="section-title">Najczęstsze awarie, które usuwamy</h2>
            </div>
            <p class="section-desc">Szybka diagnoza, dobór metody i usunięcie zatoru - mechanicznie lub ciśnieniowo. Działamy w Zielonce i okolicach.</p>
          </div>

          <div class="service-grid">
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">💧</div>
              <h3>Udrażnianie rur</h3>
              <p>Mechaniczne usuwanie zatorów w odpływach kuchennych, łazienkowych i podejściach kanalizacyjnych. Bez obiecywania cudów, za to z dobrą diagnostyką.</p>
              <a class="service-card-new__more" href={phoneHref}>Zgłoś problem →</a>
            </article>

            <article class="service-card-new reveal">
              <div class="service-card-new__icon">🚽</div>
              <h3>Przepychanie WC</h3>
              <p>Pomoc przy niedrożnej muszli, cofaniu wody i problemach z odpływem. Najpierw ocena sytuacji, potem dobranie narzędzia do rodzaju zatoru.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>

            <article class="service-card-new reveal">
              <div class="service-card-new__icon">🌀</div>
              <h3>WUKO</h3>
              <p>Czyszczenie ciśnieniowe dłuższych odcinków kanalizacji, przyłączy i rur zewnętrznych. Dobra metoda przy osadach, piasku i powtarzających się niedrożnościach.</p>
              <a class="service-card-new__more" href={phoneHref}>Zapytaj o termin →</a>
            </article>

            <article class="service-card-new reveal">
              <div class="service-card-new__icon">📹</div>
              <h3>Kamera inspekcyjna</h3>
              <p>Przy nawracających problemach warto sprawdzić, czy w rurze nie ma przeciwspadku, uszkodzenia, osadu albo błędu montażowego.</p>
              <a class="service-card-new__more" href={phoneHref}>Umów sprawdzenie →</a>
            </article>

            <article class="service-card-new reveal">
              <div class="service-card-new__icon">🏢</div>
              <h3>Piony kanalizacyjne</h3>
              <p>Pomoc przy problemach w blokach, lokalach usługowych i budynkach wielorodzinnych. Gdy zator jest głębiej, sama chemia zwykle nie rozwiązuje przyczyny.</p>
              <a class="service-card-new__more" href={phoneHref}>Skonsultuj awarię →</a>
            </article>

            <article class="service-card-new reveal">
              <div class="service-card-new__icon">🔧</div>
              <h3>Drobna hydraulika</h3>
              <p>Syfony, odpływy, podejścia, nieszczelności i elementy, które często wychodzą przy okazji udrażniania. Prosty zakres, szybka decyzja, jasny kontakt.</p>
              <a class="service-card-new__more" href={phoneHref}>Porozmawiaj z hydraulikiem →</a>
            </article>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           PROCES
      ════════════════════════════════════════════════════ -->
      <section id="proces" class="new-section">
        <div class="container bento">
          <article class="panel diagnostic reveal">
            <p class="section-kicker">Diagnoza przed działaniem</p>
            <h2>Nie każda zatkana rura ma tę samą przyczynę</h2>
            <p>Inaczej podchodzi się do tłuszczu w kuchni, inaczej do zatoru w WC, a jeszcze inaczej do źle wykonanego podejścia lub odcinka ze zbyt małym spadkiem.</p>
            <ul class="check-list">
              <li>ustalenie, gdzie zatrzymuje się woda,</li>
              <li>dobór sprężyny elektrycznej, WUKO albo kamery,</li>
              <li>jasna informacja, kiedy problem może wracać,</li>
              <li>kontakt telefoniczny bez ukrywania numeru.</li>
            </ul>
          </article>

          <aside class="panel process-panel reveal">
            <h2>Jak działamy?</h2>
            <div class="step">
              <span class="step__num">1</span>
              <strong>Krótki opis awarii</strong>
              <span>Klient mówi, czy problem dotyczy zlewu, WC, wanny, kratki, pionu albo kanalizacji zewnętrznej.</span>
            </div>
            <div class="step">
              <span class="step__num">2</span>
              <strong>Dobór sprzętu</strong>
              <span>Na podstawie objawu dobieramy sprężynę, ciśnienie WUKO lub kamerę do kontroli wnętrza rury.</span>
            </div>
            <div class="step">
              <span class="step__num">3</span>
              <strong>Udrażnianie i test</strong>
              <span>Po usunięciu zatoru sprawdzamy odpływ wody i informujemy, co mogło powodować problem.</span>
            </div>
          </aside>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           CENNIK
      ════════════════════════════════════════════════════ -->
      <section id="cennik" class="pricing-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker">Orientacyjne ceny</p>
              <h2 class="section-title">Jasna cena zanim weźmiemy się do pracy</h2>
            </div>
            <p class="section-desc">Kwoty orientacyjne. Dokładna wycena przez telefon - bezpłatnie, bez zobowiązań.</p>
          </div>
          <div class="price-grid">
            <article class="price-card reveal">
              <span class="price-card__tag">Większy zakres</span>
              <h3>Montaż baterii</h3>
              <p>Prace przy trudniejszych niedrożnościach, dłuższych odcinkach kanalizacji i powracających problemach.</p>
              <div class="price-val">od 250 zł <small>orientacyjnie</small></div>
            </article>
            <article class="price-card price-card--featured reveal">
              <span class="price-card__tag">Pilna awaria</span>
              <h3>Nagła awaria</h3>
              <p>Niedrożna muszla, cofająca się woda, problem z odpływem lub zator na dalszym odcinku podejścia.</p>
              <div class="price-val">do uzgodnienia</div>
            </article>
            <article class="price-card reveal">
              <span class="price-card__tag">Najczęstsze</span>
              <h3>Naprawa spłuczki</h3>
              <p>Cieknąca spłuczka, słaby spływ, uszkodzony mechanizm lub zawór. Szybka diagnoza i wymiana części na miejscu. Cieknąca spłuczka - kompakt.</p>
              <div class="price-val">300 zł <small>orientacyjnie</small></div>
            </article>
          </div>
          <p class="price-note">Podane ceny dotyczą usług w dni robocze w standardowych godzinach. W soboty, niedziele, święta oraz po 20:00 stawki mogą być wyższe - dokładna kwota zawsze ustalana telefonicznie.</p>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           OPINIA
      ════════════════════════════════════════════════════ -->
      <section class="testimonial-strip">
        <div class="container">
          <div class="strip-card reveal">
            <div>
              <div class="rating">★★★★★ 558 opinii Google</div>
            </div>
            <blockquote>
              „Szybka pomoc przy pękniętej rurze w nocy. Fachowiec był pod blokiem w 20 minut. Wszystko sprawnie naprawione, czysto i profesjonalnie."
            </blockquote>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           FAQ
      ════════════════════════════════════════════════════ -->
      <section id="faq" class="faq-section">
        <div class="container faq-grid">
          <div class="reveal">
            <p class="section-kicker">Pytania klientów</p>
            <h2 class="section-title">FAQ</h2>
            <p class="section-desc">Najczęstsze pytania przed podjęciem decyzji o telefonie.</p>
          </div>
          <div class="faq-list reveal">
            <article class="faq-item is-open">
              <button class="faq-question" type="button">
                <span>Dlaczego rura zatyka się ponownie?</span><span>+</span>
              </button>
              <div class="faq-answer">
                <p>Najczęściej przez tłuszcz, osad, zbyt mały spadek, źle wykonane podejście albo zator znajdujący się głębiej niż sam syfon.</p>
              </div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button">
                <span>Czy chemia do rur wystarczy?</span><span>+</span>
              </button>
              <div class="faq-answer">
                <p>Przy lekkim osadzie czasem pomaga, ale przy twardym zatorze może pogorszyć sytuację i utrudnić późniejszą pracę mechaniczną.</p>
              </div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button">
                <span>Kiedy potrzebna jest kamera?</span><span>+</span>
              </button>
              <div class="faq-answer">
                <p>Gdy problem wraca, woda cofa się mimo udrażniania albo podejrzewamy uszkodzenie, przeciwspadek lub zalegający osad w rurze.</p>
              </div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button">
                <span>Czy da się podać cenę przez telefon?</span><span>+</span>
              </button>
              <div class="faq-answer">
                <p>Da się podać widełki, ale dokładna cena zależy od rodzaju awarii, dostępu do instalacji i metody potrzebnej do usunięcia zatoru.</p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           CTA
      ════════════════════════════════════════════════════ -->
      <section id="kontakt" class="cta-section">
        <div class="container">
          <div class="final-cta reveal">
            <div class="final-cta__content">
              <div>
                <h2>Masz zatkany odpływ? Zadzwoń i opisz objaw.</h2>
                <p>Powiedz, gdzie stoi woda, czy problem wraca i czego już próbowano. Po krótkiej rozmowie łatwiej dobrać właściwą metodę udrażniania.</p>
              </div>
              <div class="final-cta__box">
                <strong>{phoneLabel}</strong>
                <span>Pogotowie hydrauliczne - Zielonka i okolice, 24/7</span>
                <div style="height: 18px"></div>
                <a class="btn-new btn-new--primary" href={phoneHref}>📞 Zadzwoń teraz</a>
              </div>
            </div>
          </div>
        </div>
      </section>

    
      <!-- ═══════════════════════════════════════════════════
           OKOLICE
      ════════════════════════════════════════════════════ -->
      <section class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker">Obszar działania</p>
              <h2 class="section-title">Zielonka i okolice</h2>
            </div>
            <p class="section-desc">Dojeżdżamy do Zielonki oraz sąsiednich miejscowości. Zobacz stronę dla swojej okolicy.</p>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-start">
            <a class="btn-new btn-new--ghost" href="/hydraulik-zabki">Hydraulik Ząbki</a>
