  <!-- Snow globe - efekt dla przycisków hero -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      function initGlobe(canvasId, btnSelector, colors) {
        const canvas = document.getElementById(canvasId);
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let W, H, particles = [], shake = 0;

        function resize() {
          const r = canvas.parentElement.getBoundingClientRect();
          W = r.width; H = r.height;
          canvas.width = W * devicePixelRatio;
          canvas.height = H * devicePixelRatio;
          ctx.scale(devicePixelRatio, devicePixelRatio);
        }
        window.addEventListener('resize', resize);
        resize();

        class Glitter {
          constructor(init) {
            this.x = Math.random() * W;
            this.y = init ? Math.random() * H : H * 0.3 + Math.random() * H * 0.7;
            this.vx = (Math.random() - 0.5) * 0.6;
            this.vy = (Math.random() - 0.5) * 0.6;
            this.size = Math.random() * 2.2 + 0.6;
            this.rot = Math.random() * Math.PI * 2;
            this.rotV = (Math.random() - 0.5) * 0.07;
            this.alpha = Math.random() * 0.55 + 0.3;
            this.phase = Math.random() * Math.PI * 2;
            this.phaseV = Math.random() * 0.04 + 0.015;
            this.color = colors[Math.floor(Math.random() * colors.length)];
          }
          update() {
            if (shake > 0.02) {
              this.vx += (Math.random() - 0.5) * shake * 0.6;
              this.vy += (Math.random() - 0.5) * shake * 0.6;
            }
            this.vx *= 0.986; this.vy *= 0.986;
            this.vy += 0.0028;
            this.x += this.vx; this.y += this.vy;
            this.rot += this.rotV;
            this.phase += this.phaseV;
            const pad = 2;
            if (this.x < pad)   { this.x = pad;   this.vx =  Math.abs(this.vx) * 0.93; }
            if (this.x > W-pad) { this.x = W-pad;  this.vx = -Math.abs(this.vx) * 0.93; }
            if (this.y < pad)   { this.y = pad;   this.vy =  Math.abs(this.vy) * 0.93; }
            if (this.y > H-pad) { this.y = H-pad;  this.vy = -Math.abs(this.vy) * 0.93; }
          }
          draw() {
            const spark = (Math.sin(this.phase) + 1) / 2;
            const a = this.alpha * (0.25 + spark * 0.75);
            const s = this.size * (0.55 + spark * 0.45);
            ctx.save();
            ctx.globalAlpha = a;
            ctx.translate(this.x, this.y);
            ctx.rotate(this.rot);
            ctx.beginPath();
            ctx.moveTo(0, -s * 1.6); ctx.lineTo(s * 0.65, 0);
            ctx.lineTo(0,  s * 1.6); ctx.lineTo(-s * 0.65, 0);
            ctx.closePath();
            ctx.fillStyle = this.color;
            ctx.shadowBlur = 3 + spark * 9;
            ctx.shadowColor = this.color;
            ctx.fill();
            ctx.restore();
          }
        }

        for (let i = 0; i < 50; i++) particles.push(new Glitter(true));
        const btn = canvas.closest(btnSelector);
        if (btn) btn.addEventListener('mouseenter', () => { shake = 1.1; });

        (function loop() {
          ctx.clearRect(0, 0, W, H);
          shake *= 0.93;
          particles.forEach(p => { p.update(); p.draw(); });
          requestAnimationFrame(loop);
        })();
      }

      const orange = ['#FFB800','#FF8C00','#FFDD55','#FF6A00','#FFC830','#FFE066'];
      const blue   = ['#1565C0','#1976D2','#42A5F5','#0D47A1','#2196F3','#5C9BF5','#0A66C2','#64B5F6'];
      initGlobe('canvas-1', '.btn-primary', orange);
      initGlobe('canvas-2', '.btn-secondary', blue);
    });
  </script>

  <!-- Typewriter hero-subtitle -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const el = document.querySelector('.hero-subtitle');
      if (!el) return;
      const text = el.textContent.trim();
      el.textContent = '';
      el.classList.add('typewriter-active');

      setTimeout(() => {
        let i = 0;
        function type() {
          if (i < text.length) {
            el.textContent = text.slice(0, i + 1);
            i++;
            setTimeout(type, 80);
          } else {
            el.classList.remove('typewriter-active');
          }
        }
        type();
      }, 2500);
    });
  </script>

  <!-- Reveal, FAQ, bg switcher -->
  <script>
    // Reveal on scroll
    const revealEls = document.querySelectorAll('.reveal');
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); revealObs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(el => revealObs.observe(el));

    // FAQ accordion
    document.querySelectorAll('.faq-item').forEach(item => {
      item.querySelector('.faq-question').addEventListener('click', () => {
        document.querySelectorAll('.faq-item').forEach(o => { if (o !== item) o.classList.remove('is-open'); });
        item.classList.toggle('is-open');
      });
    });

    // Background switcher
    document.querySelectorAll('[data-bg-choice]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.body.dataset.bg = btn.dataset.bgChoice;
        document.querySelectorAll('[data-bg-choice]').forEach(b => b.classList.toggle('is-active', b === btn));
      });
    });
  </script>

