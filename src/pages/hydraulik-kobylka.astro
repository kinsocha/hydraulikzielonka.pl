---
import '../styles/sections.css';

const phone = '';                 // <- WPISZ numer, np. '500 600 700'
const phoneLabel = phone || 'Zadzwoń teraz';
const phoneHref = phone ? `tel:+48${phone.replace(/\s/g, '')}` : '#';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  <title>Hydraulik Kobyłka - usługi hydrauliczne i udrażnianie | Hydraulik Zielonka</title>
  <meta name="description" content="Hydraulik Kobyłka - udrażnianie kanalizacji, naprawa instalacji, montaż armatury, pogotowie. Szybki dojazd, wycena przed pracą." />

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Hydraulik Zielonka - Kobyłka",
  "url": "https://hydraulik-zielonka.pl/hydraulik-kobylka",
  "telephone": "",
  "areaServed": {
    "@type": "City",
    "name": "Kobyłka"
  },
  "priceRange": "$$"
}
  </script>

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Ile kosztuje udrażnianie w Kobyłce?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Udrażnianie zlewu lub WC zaczyna się zwykle od ok. 150 zł, czyszczenie pionu od ok. 300 zł. Cena zależy od dostępu do rur i skali problemu. Podajemy ją przed przyjazdem."
      }
    },
    {
      "@type": "Question",
      "name": "Macie sprzęt do starych instalacji?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. W starszych budynkach trafiają się rury żeliwne i ceramiczne. Dobieramy do nich ciśnienie ostrożnie, żeby skutecznie wyczyścić rurę i jej nie uszkodzić."
      }
    },
    {
      "@type": "Question",
      "name": "Czy robicie inspekcję kamerą?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. Inspekcja kamerą przydaje się przy nawracających zatorach i przed remontem. Pozwala zlokalizować pęknięcia, załamania i wrastające korzenie."
      }
    },
    {
      "@type": "Question",
      "name": "Jak szybko dojeżdżacie do Kobyłki?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Najczęściej tego samego dnia. W nagłych awariach, gdy cofa się kanalizacja, staramy się przyjechać priorytetowo."
      }
    },
    {
      "@type": "Question",
      "name": "Czy wystawiacie fakturę dla wspólnoty?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. Współpracujemy z administracjami i wspólnotami, wystawiamy faktury VAT i możemy umówić okresową konserwację pionów."
      }
    }
  ]
}
  </script>
</head>

<body data-bg="premium">
  <div class="page-shell">

    <header class="topbar">
      <div class="container nav">
        <a href="/" class="logo" aria-label="Hydraulik Zielonka strona główna">
          <span class="logo__mark">🔧</span>
          <span class="logo__name">Hydraulik Zielonka</span>
        </a>
        <nav class="nav__links" aria-label="Główna nawigacja">
          <a href="/#uslugi">Usługi</a>
          <a href="/#proces">Jak działamy</a>
          <a href="/#cennik">Cennik</a>
          <a href="/#faq">FAQ</a>
          <a href="/#kontakt">Kontakt</a>
        </nav>
        <div class="nav__actions">
          <a class="phone-link" href={phoneHref}><span>☎</span> {phoneLabel}</a>
          <a class="btn-new btn-new--primary" href={phoneHref}>Zadzwoń teraz</a>
        </div>
      </div>
    </header>

    <main>
      <!-- INTRO -->
      <section class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker"><a href="/" style="color:inherit">Strona główna</a> / Hydraulik Kobyłka</p>
              <h2 class="section-title">Hydraulik Kobyłka - udrażnianie i naprawy</h2>
            </div>
            <p class="section-desc">Dojeżdżamy do Kobyłka przy awariach, zatkanych odpływach i pracach instalacyjnych. Wycena przed przyjazdem, faktura VAT.</p>
          </div>
          <div class="hero-buttons" style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px">
            <a class="btn-new btn-new--primary" href={phoneHref}>📞 {phoneLabel}</a>
            <a class="btn-new btn-new--ghost" href="#zakres">Zobacz zakres usług</a>
          </div>
        </div>
      </section>

      <!-- ZAKRES -->
      <section id="zakres" class="new-section">
        <div class="container">
          <div class="section-head reveal">
            <div>
              <p class="section-kicker">Co robimy w Kobyłka</p>
              <h2 class="section-title">Zakres usług</h2>
            </div>
            <p class="section-desc">Dobieramy metodę do problemu i instalacji. Mieszkania, domy jednorodzinne, bloki i lokale usługowe.</p>
          </div>
          <div class="service-grid">
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">💧</div>
              <h3>Udrażnianie kanalizacji</h3>
              <p>Mechaniczne i ciśnieniowe usuwanie zatorów w zlewach, toaletach, pionach i odpływach.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">🔧</div>
              <h3>Naprawa instalacji</h3>
              <p>Wymiana zaworów, naprawa przecieków, regeneracja uszczelek, podłączenia AGD.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
            <article class="service-card-new reveal">
              <div class="service-card-new__icon">📹</div>
              <h3>Inspekcja kamerą</h3>
              <p>Diagnostyka wnętrza rur kamerą. Lokalizacja uszkodzeń, załamań i wrastających korzeni.</p>
              <a class="service-card-new__more" href={phoneHref}>Zadzwoń →</a>
            </article>
          </div>
        </div>
      </section>

      <!-- OBSZAR -->
      <section class="new-section">
        <div class="container bento">
          <article class="panel diagnostic reveal">
            <p class="section-kicker">Opis</p>
            <h2>Hydraulik i udrażnianie w Kobyłka</h2>
            <p>Kobyłka łączy starszą zabudowę z nowymi osiedlami domów i szeregowców. W starszych budynkach problemem bywa wiek rur i osady narastające latami, w nowszych intensywna eksploatacja instalacji. Pomagamy przy zatkanych zlewach, brodzikach i toaletach, naprawiamy nieszczelne złącza i wymieniamy zużytą armaturę. Tam, gdzie zator wraca, robimy inspekcję kamerą i pokazujemy, co dzieje się w rurze.</p>
          </article>
          <aside class="panel process-panel reveal">
            <h2>Obszar działania</h2>
            <p style="color:var(--muted);margin:0 0 6px">Osiedla i części miejscowości:</p>
            <ul class="check-list">
              <li>Centrum</li>
              <li>Maciołki</li>
              <li>Stefanówka</li>
              <li>okolice dworca</li>
            </ul>
            <p style="color:var(--muted);margin:14px 0 0;line-height:1.6"><strong style="color:var(--ink)">Dojeżdżamy m.in. na ulice:</strong> Załuskiego • Napoleona • Jana Pawła II • Ceglana • Nadarzyńska • Warszawska • Wyzwolenia • Poniatowskiego • Sikorskiego • Kościuszki • Leśna • Dworcowa • Orszagha • Załęże i pozostałe ulice miejscowości Kobyłka.</p>
          </aside>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" class="faq-section">
        <div class="container faq-grid">
          <div class="reveal">
            <p class="section-kicker">Pytania klientów</p>
            <h2 class="section-title">FAQ - Hydraulik Kobyłka</h2>
            <p class="section-desc">Najczęstsze pytania przed telefonem.</p>
          </div>
          <div class="faq-list reveal">
            <article class="faq-item is-open">
              <button class="faq-question" type="button"><span>Ile kosztuje udrażnianie w Kobyłce?</span><span>+</span></button>
              <div class="faq-answer"><p>Udrażnianie zlewu lub WC zaczyna się zwykle od ok. 150 zł, czyszczenie pionu od ok. 300 zł. Cena zależy od dostępu do rur i skali problemu. Podajemy ją przed przyjazdem.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Macie sprzęt do starych instalacji?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak. W starszych budynkach trafiają się rury żeliwne i ceramiczne. Dobieramy do nich ciśnienie ostrożnie, żeby skutecznie wyczyścić rurę i jej nie uszkodzić.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Czy robicie inspekcję kamerą?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak. Inspekcja kamerą przydaje się przy nawracających zatorach i przed remontem. Pozwala zlokalizować pęknięcia, załamania i wrastające korzenie.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Jak szybko dojeżdżacie do Kobyłki?</span><span>+</span></button>
              <div class="faq-answer"><p>Najczęściej tego samego dnia. W nagłych awariach, gdy cofa się kanalizacja, staramy się przyjechać priorytetowo.</p></div>
            </article>
            <article class="faq-item">
              <button class="faq-question" type="button"><span>Czy wystawiacie fakturę dla wspólnoty?</span><span>+</span></button>
              <div class="faq-answer"><p>Tak. Współpracujemy z administracjami i wspólnotami, wystawiamy faktury VAT i możemy umówić okresową konserwację pionów.</p></div>
            </article>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section id="kontakt" class="cta-section">
        <div class="container">
          <div class="final-cta reveal">
            <div class="final-cta__content">
              <div>
                <h2>Potrzebujesz hydraulika w Kobyłka?</h2>
                <p>Opisz krótko problem przez telefon - łatwiej dobrać metodę i podać orientacyjny koszt. Działamy w Kobyłka i okolicach.</p>
              </div>
              <div class="final-cta__box">
                <strong>{phoneLabel}</strong>
                <span>Hydraulik Zielonka - Kobyłka i okolice</span>
                <div style="height: 18px"></div>
                <a class="btn-new btn-new--primary" href={phoneHref}>📞 Zadzwoń teraz</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- INNE MIEJSCOWOŚCI -->
      <section class="new-section">
        <div class="container">
          <h2 class="section-title" style="margin-bottom:18px">Działamy też w okolicy</h2>
          <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-start">
            <a class="btn-new btn-new--ghost" href="/hydraulik-zabki">Hydraulik Ząbki</a>
            <a class="btn-new btn-new--ghost" href="/hydraulik-marki">Hydraulik Marki</a>
            <a class="btn-new btn-new--ghost" href="/hydraulik-wolomin">Hydraulik Wołomin</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="new-footer">
      <div class="container footer-grid">
        <div>© 2026 Hydraulik Zielonka</div>
        <div>Udrażnianie • Naprawy • Montaż armatury • Inspekcja kamerą</div>
      </div>
    </footer>

    <a class="mobile-cta" href={phoneHref}>📞 Zadzwoń: {phoneLabel}</a>
  </div>

  <script>
    // reveal
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
    // FAQ
    document.querySelectorAll('.faq-item').forEach(item => {
      item.querySelector('.faq-question').addEventListener('click', () => {
        document.querySelectorAll('.faq-item').forEach(o => { if (o !== item) o.classList.remove('is-open'); });
        item.classList.toggle('is-open');
      });
    });
  </script>
</body>
</html>
